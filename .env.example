# OpenAI
OPENAI_API_KEY=sk-...

# Google OAuth
GOOGLE_CREDENTIALS_PATH=./credentials.json

# User identity
USER_NAME=Your Name
USER_EMAIL=you@gmail.com
USER_SIGNATURE=Best,\nYour Name\nTitle | Company

# Agent behavior
AUTO_SEND_THRESHOLD=0.90
MAX_EMAILS_PER_RUN=20
DEMO_MODE=false

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=email-triage-agent
